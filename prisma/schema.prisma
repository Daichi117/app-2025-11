// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. ユーザー関連
// ============================================
model User {
  id              String           @id @default(uuid())
  email           String           @unique
  name            String
  password_hash   String
  base_currency   String           @default("JPY")
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  
  // リレーション
  auth_logs       auth_logs[]
  refresh_tokens  refresh_tokens[]
  incomes         Income[]         // ← 追加
  expenses        Expense[]        // ← 追加
}

model auth_logs {
  id         String   @id @default(uuid())
  user_id    String
  success    Boolean
  ip_address String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model refresh_tokens {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ============================================
// 2. 収入（新規追加）
// ============================================
model Income {
  id         String   @id @default(uuid())
  user_id    String
  amount     Float                    // 金額
  category   String                   // SALARY, SIDEJOB, BONUS, INVESTMENTS, OTHER
  date       DateTime                 // 収入日
  memo       String?                  // メモ（任意）
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  
  // リレーション
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  // インデックス（検索高速化）
  @@index([user_id, date])
  @@index([user_id, category])
}

// ============================================
// 3. 支出（新規追加）
// ============================================
model Expense {
  id         String   @id @default(uuid())
  user_id    String
  amount     Float                    // 金額
  type       String                   // FIXED（固定費）or VARIABLE（変動費）
  category   String                   // RENT, FOOD, など
  date       DateTime                 // 支出日
  memo       String?                  // メモ（任意）
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  
  // リレーション
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  // インデックス（検索高速化）
  @@index([user_id, date])
  @@index([user_id, type])
  @@index([user_id, category])
}